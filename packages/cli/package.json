{
  "name": "packdaddy",
  "version": "0.2.0",
  "type": "module",
  "description": "Zero-dependency CLI to audit package.json — find unused, outdated, vulnerable, and heavy dependencies.",
  "keywords": [
    "dependency",
    "dependencies",
    "audit",
    "unused",
    "outdated",
    "size",
    "cli",
    "npm",
    "pnpm",
    "yarn",
    "bun",
    "package-json",
    "security",
    "vulnerability",
    "cve",
    "node-modules",
    "devtools",
    "dx"
  ],
  "homepage": "https://packdaddy.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/01shrvan/packdaddy.git"
  },
  "bugs": {
    "url": "https://github.com/01shrvan/packdaddy/issues"
  },
  "license": "MIT",
  "author": "01shrvan",
  "bin": {
    "packdaddy": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^25.1.0",
    "@workspace/typescript-config": "workspace:*",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0"
  }
}
